{
  "name": "personal-cfo-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous personal CFO agent — crypto liquidity to fiat commerce in Nigeria",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/ensure-sqlite.mjs && tsx src/cli/index.ts",
    "demo": "node scripts/ensure-sqlite.mjs && tsx src/demo/index.ts",
    "build": "tsc",
    "test": "node scripts/ensure-sqlite.mjs && vitest run",
    "test:watch": "vitest",
    "audit": "tsx src/cli/audit.ts",
    "policy": "tsx src/cli/policy.ts",
    "kill": "tsx src/cli/kill.ts",
    "resume": "tsx src/cli/resume.ts",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/ensure-sqlite.mjs"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.106.0",
    "@lifi/sdk": "^3.7.9",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@noble/ciphers": "^1.3.0",
    "@noble/hashes": "^1.8.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.5.0",
    "node-cron": "^3.0.3",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "viem": "^2.31.0",
    "yaml": "^2.8.0",
    "zod": "^3.25.51"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
